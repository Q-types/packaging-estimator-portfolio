# KSP Packaging Estimator - Environment Configuration
# Copy this file to .env and update values for your environment

# Application
APP_NAME="KSP Packaging Estimator"
APP_VERSION="0.1.0"
DEBUG=true
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Database
POSTGRES_USER=ksp
POSTGRES_PASSWORD=ksp_dev_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=ksp_estimator

# Authentication
SECRET_KEY=change-me-in-production-use-secrets-gen
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ML Configuration
ML_MIN_SAMPLES_FOR_TRAINING=50
ML_CONFIDENCE_THRESHOLD=0.7
ML_MODEL_PATH=ml/models

# File Storage
UPLOAD_DIR=data/uploads
MAX_UPLOAD_SIZE_MB=10

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
